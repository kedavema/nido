{
  "name": "@nido/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write src test vitest.config.ts",
    "format:check": "prettier --check src test vitest.config.ts",
    "lint": "eslint src test vitest.config.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nido/domain-types": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "~6.0.3",
    "vitest": "4.1.10"
  }
}
