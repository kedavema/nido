{
  "name": "@nido/mobile",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nitro-google-signin"
        ]
      }
    }
  },
  "scripts": {
    "android": "expo run:android",
    "build": "expo export --platform web",
    "build:android": "expo export --platform android --output-dir dist-android",
    "config": "expo config --type public --json",
    "dev": "expo start",
    "doctor": "expo-doctor .",
    "lint": "eslint . --max-warnings=0",
    "start": "expo start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/bricolage-grotesque": "0.4.1",
    "@expo-google-fonts/ibm-plex-sans": "0.4.1",
    "@expo/vector-icons": "15.1.1",
    "@nido/contracts": "workspace:*",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-dev-client": "~57.0.7",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-sqlite": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "firebase": "12.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-nitro-google-signin": "1.0.1",
    "react-native-nitro-modules": "0.36.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "expo-doctor": "1.20.1",
    "fake-indexeddb": "6.2.5",
    "typescript": "~6.0.3",
    "vitest": "4.1.10"
  }
}
