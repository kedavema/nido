# Public client configuration. Expo embeds every EXPO_PUBLIC_* value in the app bundle.
# These values identify public Firebase/OAuth clients; never put Admin credentials or
# private keys in this file.
# Web can use localhost. An Android emulator normally needs http://10.0.2.2:3000,
# adb reverse, or an HTTPS endpoint reachable from the device.
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_FIREBASE_API_KEY=replace-with-firebase-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-with-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=replace-with-project-id
EXPO_PUBLIC_FIREBASE_APP_ID=replace-with-firebase-web-app-id
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
# This must be the Web OAuth client ID associated with the Firebase project, not
# the Android OAuth client ID. Android also needs a separate OAuth client for
# com.nido.mobile with every applicable debug/release/Play SHA-1 registered.
# The native adapter receives this value explicitly, so no google-services.json
# is committed or required for the Android M1 flow.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=replace-with-client-id.apps.googleusercontent.com
