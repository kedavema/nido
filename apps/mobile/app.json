{
  "expo": {
    "name": "Nido",
    "slug": "nido",
    "version": "0.0.0",
    "platforms": ["android", "web"],
    "orientation": "portrait",
    "scheme": "nido",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F6F4EF",
    "android": {
      "package": "com.nido.mobile",
      "predictiveBackGestureEnabled": true,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "name": "Nido",
      "shortName": "Nido",
      "lang": "es-PY",
      "themeColor": "#F6F4EF",
      "description": "Finanzas del hogar para dos"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-nitro-google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.nido-android-only"
        }
      ],
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F4EF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
