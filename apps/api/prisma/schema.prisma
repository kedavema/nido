generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum HouseholdRole {
  OWNER
  MEMBER

  @@map("household_role")
}

enum HouseholdMemberStatus {
  ACTIVE
  REMOVED

  @@map("household_member_status")
}

enum PaymentSourceType {
  BANK_ACCOUNT
  CASH
  CREDIT_CARD
  DIGITAL_WALLET
  OTHER

  @@map("payment_source_type")
}

enum CategoryKind {
  EXPENSE
  INCOME

  @@map("category_kind")
}

enum TransactionType {
  EXPENSE
  INCOME

  @@map("transaction_type")
}

enum TransactionCurrency {
  PYG
  USD

  @@map("transaction_currency")
}

enum TransactionOrigin {
  MANUAL
  IMPORT
  RECURRING

  @@map("transaction_origin")
}

model User {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid String   @unique(map: "users_firebase_uid_key") @map("firebase_uid")
  email       String   @unique(map: "users_email_key")
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  timezone    String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  createdHouseholds   Household[]       @relation("HouseholdCreator")
  memberships         HouseholdMember[]
  ownedPaymentSources PaymentSource[]   @relation("PaymentSourceOwner")
  createdTransactions Transaction[]     @relation("TransactionCreatedBy")
  updatedTransactions Transaction[]     @relation("TransactionUpdatedBy")

  @@map("users")
}

model Household {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  baseCurrency    String   @default("PYG") @map("base_currency") @db.Char(3)
  timezone        String   @default("America/Asuncion")
  createdByUserId String   @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  creator        User              @relation("HouseholdCreator", fields: [createdByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  memberships    HouseholdMember[]
  paymentSources PaymentSource[]
  categories     Category[]
  transactions   Transaction[]

  @@index([createdByUserId], map: "households_created_by_idx")
  @@map("households")
}

model HouseholdMember {
  householdId String                @map("household_id") @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  role        HouseholdRole
  status      HouseholdMemberStatus @default(ACTIVE)
  joinedAt    DateTime              @default(now()) @map("joined_at") @db.Timestamptz(3)

  household      Household         @relation(fields: [householdId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdInvites HouseholdInvite[]

  @@id([householdId, userId], map: "household_members_pkey")
  @@index([householdId, status], map: "household_members_household_id_status_idx")
  @@index([userId, status], map: "household_members_user_id_status_idx")
  @@map("household_members")
}

model HouseholdInvite {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId     String    @map("household_id") @db.Uuid
  emailNormalized String    @map("email_normalized")
  tokenHash       String    @unique(map: "household_invites_token_hash_key") @map("token_hash") @db.Char(64)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt          DateTime? @map("used_at") @db.Timestamptz(3)
  createdByUserId String    @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  creatorMembership HouseholdMember @relation(fields: [householdId, createdByUserId], references: [householdId, userId], onDelete: Restrict, onUpdate: Cascade)

  @@index([householdId, emailNormalized], map: "household_invites_household_id_email_normalized_idx")
  @@index([householdId, expiresAt], map: "household_invites_household_id_expires_at_idx")
  @@map("household_invites")
}

model PaymentSource {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId String            @map("household_id") @db.Uuid
  name        String
  type        PaymentSourceType
  ownerUserId String?           @map("owner_user_id") @db.Uuid
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner        User?         @relation("PaymentSourceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  transactions Transaction[]

  @@index([householdId, isActive], map: "payment_sources_household_id_is_active_idx")
  @@index([ownerUserId], map: "payment_sources_owner_user_id_idx")
  @@map("payment_sources")
}

model Category {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId String       @map("household_id") @db.Uuid
  kind        CategoryKind
  parentId    String?      @map("parent_id") @db.Uuid
  name        String
  icon        String
  color       String
  sortOrder   Int          @default(0) @map("sort_order")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  parent       Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children     Category[]    @relation("CategoryHierarchy")
  transactions Transaction[]

  // DB-level rules added by hand in the migration (Prisma cannot express them):
  // - categories_active_sibling_name_key: partial unique index (household_id, kind, parent_id, name)
  //   NULLS NOT DISTINCT WHERE is_active, so the NULL-parent root level participates too.
  // - categories_two_levels_trigger (function categories_enforce_two_levels): max two levels;
  //   parent must share household and kind; a root with children cannot change household or kind.
  @@index([householdId, kind, isActive], map: "categories_household_id_kind_is_active_idx")
  @@index([parentId], map: "categories_parent_id_idx")
  @@map("categories")
}

model Transaction {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId        String              @map("household_id") @db.Uuid
  type               TransactionType
  amount             Decimal             @db.Decimal(18, 2)
  currency           TransactionCurrency
  fxRateToBase       Decimal?            @map("fx_rate_to_base") @db.Decimal(18, 4)
  baseAmountPyg      Decimal             @map("base_amount_pyg") @db.Decimal(18, 0)
  occurredAt         DateTime            @map("occurred_at") @db.Timestamptz(3)
  localDate          DateTime            @map("local_date") @db.Date
  categoryId         String              @map("category_id") @db.Uuid
  paymentSourceId    String?             @map("payment_source_id") @db.Uuid
  description        String
  notes              String?
  origin             TransactionOrigin   @default(MANUAL)
  sourceOccurrenceId String?             @unique(map: "transactions_source_occurrence_id_key") @map("source_occurrence_id") @db.Uuid
  externalReference  String?             @map("external_reference")
  clientMutationId   String?             @map("client_mutation_id") @db.Uuid
  createdBy          String              @map("created_by") @db.Uuid
  updatedBy          String              @map("updated_by") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  household     Household      @relation(fields: [householdId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  paymentSource PaymentSource? @relation(fields: [paymentSourceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  creator       User           @relation("TransactionCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Cascade)
  updater       User           @relation("TransactionUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // DB-level rules added by hand in the migration (Prisma cannot express them):
  // - transactions_created_by_client_mutation_id_key: partial unique index
  //   (created_by, client_mutation_id) WHERE client_mutation_id IS NOT NULL, so idempotent
  //   client retries are deduplicated per author.
  // - transactions_household_payment_source_external_reference_key: partial unique index
  //   (household_id, payment_source_id, external_reference) WHERE external_reference IS NOT NULL,
  //   so imports are not double-booked.
  // - transactions_category_and_payment_source_trigger (function
  //   transactions_enforce_category_and_payment_source): the referenced category must belong to
  //   the same household and have a kind matching the transaction type; when payment_source_id is
  //   set, the referenced payment source must belong to the same household.
  @@index([householdId, localDate(sort: Desc)], map: "transactions_household_id_local_date_idx")
  @@index([householdId, categoryId, localDate], map: "transactions_household_id_category_id_local_date_idx")
  @@index([householdId, paymentSourceId, localDate], map: "transactions_household_id_payment_source_id_local_date_idx")
  @@map("transactions")
}
